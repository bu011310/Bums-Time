<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>BUMS Time</title>
<style>
:root {
  --accent: #6C63FF;
  --accent2: #FF6584;
  --accent3: #43E6FC;
  --bg-dark: #0a0a1a;
  --glass: rgba(255,255,255,0.07);
  --glass-border: rgba(255,255,255,0.13);
  --text: #f0f0ff;
  --text-muted: rgba(240,240,255,0.5);
  --nav-h: 80px;
  --radius: 22px;
  --radius-sm: 14px;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
body{font-family:-apple-system,BlinkMacSystemFont,'Inter',sans-serif;background:var(--bg-dark);color:var(--text);height:100vh;overflow:hidden;user-select:none}

/* ── ORBS ── */
.bg-orbs{position:fixed;inset:0;z-index:0;pointer-events:none}
.orb{position:absolute;border-radius:50%;filter:blur(80px);opacity:.35;animation:orbFloat 8s ease-in-out infinite}
.orb1{width:340px;height:340px;background:var(--accent);top:-80px;left:-80px;animation-delay:0s}
.orb2{width:280px;height:280px;background:var(--accent2);bottom:100px;right:-60px;animation-delay:-3s}
.orb3{width:200px;height:200px;background:var(--accent3);top:40%;left:60%;animation-delay:-5s}
@keyframes orbFloat{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(30px,-20px) scale(1.07)}66%{transform:translate(-20px,25px) scale(.95)}}

.glass{background:var(--glass);backdrop-filter:blur(24px) saturate(1.6);-webkit-backdrop-filter:blur(24px) saturate(1.6);border:1px solid var(--glass-border);border-radius:var(--radius)}

/* ══════════════════════════════
   ONBOARDING SCREEN
══════════════════════════════ */
#onboarding{
  position:fixed;inset:0;z-index:999;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:32px 28px;
  background:var(--bg-dark);
}
.ob-logo{font-size:64px;margin-bottom:16px;animation:logoBounce 1.2s ease infinite alternate}
@keyframes logoBounce{from{transform:translateY(0) scale(1)}to{transform:translateY(-10px) scale(1.05)}}
.ob-brand{font-size:38px;font-weight:800;letter-spacing:-1px;background:linear-gradient(135deg,var(--accent),var(--accent2),var(--accent3));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:6px}
.ob-tagline{font-size:15px;color:var(--text-muted);margin-bottom:44px;text-align:center;line-height:1.5}

.ob-card{width:100%;max-width:360px;padding:28px 24px;border-radius:28px;background:rgba(255,255,255,0.06);backdrop-filter:blur(30px);border:1px solid rgba(255,255,255,0.12)}
.ob-step{display:none;flex-direction:column;gap:16px}
.ob-step.active{display:flex}
.ob-step-title{font-size:20px;font-weight:700;text-align:center}
.ob-step-sub{font-size:13px;color:var(--text-muted);text-align:center;margin-top:-8px;line-height:1.6}

.ob-input{
  width:100%;padding:16px 18px;border-radius:16px;
  background:rgba(255,255,255,0.08);border:1.5px solid rgba(255,255,255,0.12);
  color:var(--text);font-size:17px;font-family:inherit;outline:none;
  transition:border-color .2s,background .2s;text-align:center;
}
.ob-input:focus{border-color:var(--accent);background:rgba(108,99,255,0.1)}
.ob-input::placeholder{color:var(--text-muted)}

.ob-btn{
  width:100%;padding:16px;border-radius:16px;border:none;cursor:pointer;
  font-size:16px;font-weight:700;font-family:inherit;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  color:#fff;box-shadow:0 8px 28px rgba(108,99,255,0.4);
  transition:transform .15s,opacity .15s;
}
.ob-btn:active{transform:scale(.96);opacity:.9}
.ob-btn-ghost{background:transparent;border:1.5px solid var(--glass-border);color:var(--text-muted);box-shadow:none}

.avatar-choose{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
.av-opt{
  width:56px;height:56px;border-radius:50%;font-size:26px;
  display:flex;align-items:center;justify-content:center;
  background:rgba(255,255,255,0.08);border:2.5px solid transparent;
  cursor:pointer;transition:all .2s;
}
.av-opt.picked{border-color:var(--accent);background:rgba(108,99,255,0.2);transform:scale(1.12)}

.ob-dots{display:flex;gap:7px;justify-content:center;margin-top:20px}
.ob-dot{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,0.2);transition:all .3s}
.ob-dot.active{background:var(--accent);width:20px;border-radius:4px}

/* Welcome animation */
#welcomeScreen{
  position:fixed;inset:0;z-index:998;
  display:none;flex-direction:column;align-items:center;justify-content:center;
  background:var(--bg-dark);
}
.welcome-emoji{font-size:80px;animation:popIn .6s cubic-bezier(.34,1.56,.64,1)}
.welcome-text{font-size:28px;font-weight:700;margin-top:20px;text-align:center}
.welcome-sub{font-size:15px;color:var(--text-muted);margin-top:8px}
.welcome-bar{
  width:180px;height:4px;border-radius:2px;background:rgba(255,255,255,0.1);
  margin-top:40px;overflow:hidden;
}
.welcome-bar-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:2px;width:0;transition:width 2s linear}
@keyframes popIn{from{transform:scale(0) rotate(-20deg)}to{transform:scale(1) rotate(0)}}

/* ══════════════════════════════
   MAIN APP
══════════════════════════════ */
#app{position:relative;z-index:1;width:100%;max-width:430px;margin:0 auto;height:100vh;display:flex;flex-direction:column;overflow:hidden;opacity:0;pointer-events:none;transition:opacity .4s}
#app.visible{opacity:1;pointer-events:all}

.page{display:none;flex:1;overflow-y:auto;padding:0 0 calc(var(--nav-h)+12px) 0;scrollbar-width:none}
.page::-webkit-scrollbar{display:none}
.page.active{display:flex;flex-direction:column}

.page-header{padding:48px 20px 18px;display:flex;align-items:flex-end;justify-content:space-between}
.page-title{font-size:30px;font-weight:700;letter-spacing:-.5px}
.page-subtitle{font-size:13px;color:var(--text-muted);margin-top:3px}
.section-label{padding:6px 20px 10px;font-size:11px;font-weight:700;letter-spacing:1.2px;color:var(--text-muted);text-transform:uppercase}

/* ── BOTTOM NAV ── */
.bottom-nav{
  position:fixed;bottom:0;left:50%;transform:translateX(-50%);
  width:100%;max-width:430px;height:var(--nav-h);z-index:100;
  display:flex;align-items:center;justify-content:space-around;
  padding:0 10px 16px;
  background:rgba(10,10,26,.65);
  backdrop-filter:blur(40px) saturate(2);-webkit-backdrop-filter:blur(40px) saturate(2);
  border-top:1px solid rgba(255,255,255,.09);
}
.nav-item{display:flex;flex-direction:column;align-items:center;gap:4px;padding:8px 12px;border-radius:16px;cursor:pointer;transition:all .25s cubic-bezier(.4,0,.2,1);position:relative}
.nav-item.active{background:rgba(108,99,255,.18)}
.nav-icon{font-size:22px;transition:transform .25s}
.nav-item.active .nav-icon{transform:scale(1.15)}
.nav-label{font-size:10px;font-weight:500;color:var(--text-muted);transition:color .2s;white-space:nowrap}
.nav-item.active .nav-label{color:var(--accent)}

/* ── EMPTY STATE ── */
.empty-state{
  flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:40px 32px;text-align:center;gap:14px;
}
.empty-icon{font-size:60px;opacity:.6;animation:float 3s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.empty-title{font-size:20px;font-weight:700;opacity:.8}
.empty-sub{font-size:14px;color:var(--text-muted);line-height:1.6}
.empty-hint{
  padding:14px 20px;border-radius:16px;
  background:rgba(108,99,255,.12);border:1px dashed rgba(108,99,255,.3);
  font-size:13px;color:var(--accent);font-weight:500;cursor:pointer;
  transition:background .2s;
}
.empty-hint:active{background:rgba(108,99,255,.22)}

/* ── SCHEDULE PAGE ── */
.schedule-list{padding:0 16px;display:flex;flex-direction:column;gap:10px}
.schedule-card{
  padding:16px 18px;display:flex;align-items:center;gap:14px;
  cursor:pointer;transition:transform .18s;position:relative;overflow:hidden;
}
.schedule-card:active{transform:scale(.97)}
.schedule-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:2px;background:var(--card-accent,var(--accent))}
.card-color{width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.card-info{flex:1}
.card-title{font-size:15px;font-weight:600}
.card-time{font-size:12px;color:var(--text-muted);margin-top:3px}
.card-badge{font-size:11px;padding:3px 9px;border-radius:20px;font-weight:600}
.card-del{font-size:16px;padding:4px 6px;cursor:pointer;opacity:.5;transition:opacity .2s}
.card-del:hover{opacity:1}

.fab{
  position:fixed;bottom:calc(var(--nav-h)+16px);right:max(20px,calc(50vw - 195px));
  width:52px;height:52px;border-radius:50%;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  display:none;align-items:center;justify-content:center;
  font-size:24px;cursor:pointer;z-index:99;
  box-shadow:0 8px 32px rgba(108,99,255,.45);transition:transform .2s,box-shadow .2s;
}
.fab:active{transform:scale(.9)}

/* ── CALENDAR ── */
.cal-widget{margin:0 16px 16px;padding:20px;border-radius:var(--radius)}
.cal-nav{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.cal-nav-btn{background:var(--glass);border:1px solid var(--glass-border);border-radius:10px;width:32px;height:32px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:16px;color:var(--text)}
.cal-title{font-size:17px;font-weight:600}
.cal-days-header{display:grid;grid-template-columns:repeat(7,1fr);text-align:center;margin-bottom:8px}
.cal-day-name{font-size:11px;color:var(--text-muted);font-weight:600;padding:4px 0}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px}
.cal-cell{aspect-ratio:1;display:flex;align-items:center;justify-content:center;font-size:13px;border-radius:50%;cursor:pointer;transition:background .15s;position:relative}
.cal-cell:hover{background:var(--glass)}
.cal-cell.today{background:var(--accent);font-weight:700}
.cal-cell.selected{background:rgba(108,99,255,.3);border:1.5px solid var(--accent)}
.cal-cell.has-event::after{content:'';position:absolute;bottom:3px;left:50%;transform:translateX(-50%);width:4px;height:4px;border-radius:50%;background:var(--accent2)}
.cal-cell.other-month{color:var(--text-muted);opacity:.35}
.event-timeline{padding:0 16px;display:flex;flex-direction:column;gap:8px}
.timeline-event{padding:14px 16px;border-radius:var(--radius-sm);display:flex;align-items:center;gap:12px;cursor:pointer}
.tl-time{font-size:12px;color:var(--text-muted);min-width:45px;text-align:right}
.tl-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.tl-info .tl-title{font-size:14px;font-weight:500}
.tl-info .tl-loc{font-size:12px;color:var(--text-muted);margin-top:2px}

/* ── CLOCK ── */
.clock-tabs{display:flex;gap:6px;margin:0 16px 16px;padding:4px;background:var(--glass);border:1px solid var(--glass-border);border-radius:var(--radius-sm)}
.clock-tab{flex:1;padding:9px;text-align:center;border-radius:10px;font-size:13px;font-weight:500;cursor:pointer;transition:all .2s;color:var(--text-muted)}
.clock-tab.active{background:var(--accent);color:#fff;box-shadow:0 4px 16px rgba(108,99,255,.4)}
.clock-panel{display:none;padding:0 16px;flex-direction:column;align-items:center}
.clock-panel.active{display:flex}
.analog-clock{width:210px;height:210px;border-radius:50%;background:var(--glass);border:1px solid var(--glass-border);position:relative;margin:10px auto 20px;box-shadow:0 0 60px rgba(108,99,255,.2),inset 0 0 40px rgba(0,0,0,.2)}
.clock-face{width:100%;height:100%;position:relative}
.hand{position:absolute;bottom:50%;left:50%;transform-origin:bottom center;border-radius:3px}
.hand-hour{width:4px;height:58px;background:var(--text);margin-left:-2px}
.hand-min{width:2.5px;height:78px;background:var(--accent);margin-left:-1.25px}
.hand-sec{width:1.5px;height:86px;background:var(--accent2);margin-left:-.75px}
.clock-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:10px;height:10px;border-radius:50%;background:var(--accent);box-shadow:0 0 10px var(--accent)}
.digital-time{font-size:50px;font-weight:200;letter-spacing:2px;text-align:center;margin:16px 0}
.digital-date{font-size:14px;color:var(--text-muted);text-align:center;margin-bottom:20px}
.timer-display{font-size:68px;font-weight:200;letter-spacing:-2px;text-align:center;margin:20px 0;font-variant-numeric:tabular-nums}
.timer-controls{display:flex;gap:16px;justify-content:center;margin-bottom:24px}
.timer-btn{width:64px;height:64px;border-radius:50%;border:none;cursor:pointer;font-size:20px;display:flex;align-items:center;justify-content:center;transition:transform .15s}
.timer-btn:active{transform:scale(.9)}
.tbtn-start{background:linear-gradient(135deg,#30d158,#25a244);color:#fff;box-shadow:0 6px 20px rgba(48,209,88,.4)}
.tbtn-stop{background:rgba(255,69,58,.2);color:#ff453a;border:1.5px solid rgba(255,69,58,.3)}
.tbtn-reset{background:var(--glass);color:var(--text-muted);border:1.5px solid var(--glass-border)}
.timer-presets{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-bottom:20px}
.preset-chip{padding:8px 16px;border-radius:20px;font-size:13px;font-weight:500;background:var(--glass);border:1px solid var(--glass-border);cursor:pointer;transition:all .2s}
.preset-chip:active{background:rgba(108,99,255,.2);border-color:var(--accent);color:var(--accent)}
.alarm-list{width:100%;display:flex;flex-direction:column;gap:10px}
.alarm-item{padding:16px 18px;display:flex;align-items:center;justify-content:space-between}
.alarm-time{font-size:34px;font-weight:300;letter-spacing:-1px}
.alarm-label{font-size:13px;color:var(--text-muted);margin-top:2px}
.alarm-days{display:flex;gap:4px;margin-top:6px}
.alarm-day{font-size:10px;font-weight:600;padding:2px 5px;border-radius:5px;background:rgba(108,99,255,.15);color:var(--accent)}
.toggle{width:48px;height:28px;border-radius:14px;background:rgba(255,255,255,.1);position:relative;cursor:pointer;transition:background .3s;border:1px solid rgba(255,255,255,.1);flex-shrink:0}
.toggle.on{background:#30d158}
.toggle::after{content:'';position:absolute;top:2px;left:2px;width:22px;height:22px;border-radius:11px;background:#fff;transition:transform .3s;box-shadow:0 2px 6px rgba(0,0,0,.3)}
.toggle.on::after{transform:translateX(20px)}

/* ── WEATHER ── */
.weather-hero{margin:0 16px 16px;padding:28px 24px;background:linear-gradient(160deg,rgba(67,230,252,.2),rgba(108,99,255,.25));border:1px solid rgba(67,230,252,.25);border-radius:var(--radius);text-align:center}
.weather-icon{font-size:68px;line-height:1;margin-bottom:8px}
.weather-temp{font-size:60px;font-weight:300}
.weather-desc{font-size:17px;color:var(--text-muted);margin-top:4px}
.weather-city{font-size:14px;color:var(--accent3);margin-top:8px;font-weight:500}
.weather-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:0 16px 16px}
.weather-stat{padding:14px 10px;text-align:center;border-radius:var(--radius-sm)}
.weather-stat-val{font-size:18px;font-weight:600}
.weather-stat-label{font-size:11px;color:var(--text-muted);margin-top:4px}
.forecast-list{padding:0 16px;display:flex;flex-direction:column;gap:8px}
.forecast-item{padding:13px 18px;display:flex;align-items:center;justify-content:space-between;border-radius:var(--radius-sm)}
.forecast-day{font-size:14px;font-weight:500;width:52px}
.forecast-icon{font-size:20px}
.forecast-high{color:var(--text);font-weight:600}
.forecast-low{color:var(--text-muted)}

/* ── PROFILE ── */
.profile-hero{margin:0 16px 20px;padding:26px 20px;text-align:center;border-radius:var(--radius);background:linear-gradient(135deg,rgba(108,99,255,.2),rgba(255,101,132,.15));border:1px solid rgba(108,99,255,.2)}
.avatar-wrap{position:relative;width:86px;height:86px;margin:0 auto 14px}
.avatar{width:86px;height:86px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-size:34px;font-weight:700;color:#fff;box-shadow:0 8px 32px rgba(108,99,255,.4);border:3px solid rgba(255,255,255,.2);overflow:hidden;cursor:pointer}
.avatar img{width:100%;height:100%;object-fit:cover;display:none}
.avatar-edit{position:absolute;bottom:0;right:0;width:26px;height:26px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:12px;cursor:pointer;border:2px solid var(--bg-dark)}
.profile-name{font-size:21px;font-weight:700}
.profile-email{font-size:13px;color:var(--text-muted);margin-top:4px}
.profile-stats{display:flex;gap:0;margin-top:18px;border-top:1px solid var(--glass-border);padding-top:16px}
.pstat{flex:1;text-align:center;border-right:1px solid var(--glass-border)}
.pstat:last-child{border-right:none}
.pstat-val{font-size:20px;font-weight:700}
.pstat-label{font-size:11px;color:var(--text-muted);margin-top:3px}
.settings-list{padding:0 16px;display:flex;flex-direction:column;gap:8px}
.settings-item{padding:14px 16px;display:flex;align-items:center;gap:13px;cursor:pointer;transition:background .15s;border-radius:var(--radius-sm)}
.settings-item:active{background:rgba(255,255,255,.05)}
.si-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}
.si-info{flex:1}
.si-title{font-size:15px;font-weight:500}
.si-sub{font-size:12px;color:var(--text-muted);margin-top:2px}
.si-arrow{color:var(--text-muted);font-size:13px}
.si-badge{font-size:11px;padding:2px 8px;border-radius:10px;background:var(--accent);color:#fff;font-weight:600}
.theme-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:9px;padding:0 16px 16px}
.theme-chip{aspect-ratio:1;border-radius:var(--radius-sm);cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;font-size:10px;font-weight:600;border:2px solid transparent;transition:all .2s;padding:8px}
.theme-chip.active{border-color:var(--accent)}
.theme-icon{font-size:20px}

/* ── MODAL ── */
.modal-overlay{position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.6);backdrop-filter:blur(8px);display:flex;align-items:flex-end;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s}
.modal-overlay.open{opacity:1;pointer-events:all}
.modal{width:100%;max-width:430px;border-radius:28px 28px 0 0;background:rgba(18,18,38,.97);border:1px solid var(--glass-border);border-bottom:none;backdrop-filter:blur(40px);padding:12px 20px 40px;transform:translateY(100%);transition:transform .35s cubic-bezier(.4,0,.2,1)}
.modal-overlay.open .modal{transform:translateY(0)}
.modal-pill{width:40px;height:4px;border-radius:2px;background:rgba(255,255,255,.2);margin:0 auto 20px}
.modal-title{font-size:19px;font-weight:700;margin-bottom:18px}
.form-group{margin-bottom:14px}
.form-label{font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:7px;display:block}
.form-input{width:100%;padding:13px 15px;border-radius:var(--radius-sm);background:var(--glass);border:1px solid var(--glass-border);color:var(--text);font-size:15px;font-family:inherit;outline:none;transition:border-color .2s}
.form-input:focus{border-color:var(--accent)}
.color-picker-row{display:flex;gap:10px;flex-wrap:wrap}
.color-dot{width:30px;height:30px;border-radius:50%;cursor:pointer;border:3px solid transparent;transition:transform .15s}
.color-dot.selected,.color-dot:hover{transform:scale(1.2);border-color:rgba(255,255,255,.5)}
.modal-actions{display:flex;gap:10px;margin-top:18px}
.btn{flex:1;padding:14px;border-radius:var(--radius-sm);font-size:15px;font-weight:600;border:none;cursor:pointer;transition:opacity .2s;font-family:inherit}
.btn-primary{background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff}
.btn-secondary{background:var(--glass);color:var(--text);border:1px solid var(--glass-border)}
.btn:active{opacity:.8}

/* ── TOAST ── */
.toast{position:fixed;top:54px;left:50%;transform:translateX(-50%) translateY(-16px);background:rgba(28,28,52,.96);border:1px solid var(--glass-border);border-radius:var(--radius-sm);padding:11px 20px;font-size:14px;font-weight:500;z-index:400;opacity:0;pointer-events:none;transition:all .3s;white-space:nowrap;backdrop-filter:blur(20px)}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* ── NOTIF BANNER ── */
.notif-banner{
  margin:0 16px 14px;padding:14px 16px;
  border-radius:var(--radius-sm);
  background:linear-gradient(135deg,rgba(108,99,255,.18),rgba(67,230,252,.1));
  border:1px solid rgba(108,99,255,.25);
  display:flex;align-items:center;gap:12px;cursor:pointer;
  animation:slideIn .5s cubic-bezier(.34,1.56,.64,1);
}
@keyframes slideIn{from{transform:translateY(-10px);opacity:0}to{transform:translateY(0);opacity:1}}
.notif-banner .nb-icon{font-size:22px;flex-shrink:0}
.notif-banner .nb-text{flex:1}
.notif-banner .nb-title{font-size:14px;font-weight:600;color:var(--accent)}
.notif-banner .nb-sub{font-size:12px;color:var(--text-muted);margin-top:2px}
.notif-banner .nb-close{font-size:16px;color:var(--text-muted);padding:2px}

#avatarInput{display:none}
</style>
</head>
<body>

<div class="bg-orbs">
  <div class="orb orb1"></div>
  <div class="orb orb2"></div>
  <div class="orb orb3"></div>
</div>

<!-- ══════════ ONBOARDING ══════════ -->
<div id="onboarding">
  <div class="ob-logo">⏰</div>
  <div class="ob-brand">BUMS Time</div>
  <div class="ob-tagline">Quản lý thời gian của bạn<br>thông minh & đẹp hơn mỗi ngày</div>

  <div class="ob-card">
    <!-- Step 1: Nhập tên -->
    <div class="ob-step active" id="ob-step-1">
      <div class="ob-step-title">Xin chào! 👋</div>
      <div class="ob-step-sub">Hãy cho chúng mình biết<br>bạn muốn được gọi là gì?</div>
      <input class="ob-input" id="obName" placeholder="Tên của bạn..." maxlength="20" oninput="checkName()">
      <button class="ob-btn" id="btnStep1" onclick="goStep(2)" style="opacity:.5;pointer-events:none">Tiếp theo →</button>
    </div>

    <!-- Step 2: Chọn avatar -->
    <div class="ob-step" id="ob-step-2">
      <div class="ob-step-title">Chọn avatar 🎭</div>
      <div class="ob-step-sub">Đại diện cho phong cách của bạn</div>
      <div class="avatar-choose">
        <div class="av-opt picked" onclick="pickAv(this,'😎')">😎</div>
        <div class="av-opt" onclick="pickAv(this,'🦊')">🦊</div>
        <div class="av-opt" onclick="pickAv(this,'🐼')">🐼</div>
        <div class="av-opt" onclick="pickAv(this,'🦁')">🦁</div>
        <div class="av-opt" onclick="pickAv(this,'🐸')">🐸</div>
        <div class="av-opt" onclick="pickAv(this,'🤖')">🤖</div>
        <div class="av-opt" onclick="pickAv(this,'👾')">👾</div>
        <div class="av-opt" onclick="pickAv(this,'🌸')">🌸</div>
      </div>
      <button class="ob-btn" onclick="goStep(3)">Tiếp theo →</button>
      <button class="ob-btn ob-btn-ghost" onclick="goStep(1)" style="margin-top:-6px">← Quay lại</button>
    </div>

    <!-- Step 3: Chọn theme -->
    <div class="ob-step" id="ob-step-3">
      <div class="ob-step-title">Chọn màu yêu thích 🎨</div>
      <div class="ob-step-sub">Bạn thích phong cách nào?</div>
      <div style="display:flex;flex-direction:column;gap:9px;width:100%">
        <div class="ob-theme-opt" onclick="pickObTheme(this,'default')" style="padding:12px 16px;border-radius:14px;background:rgba(108,99,255,.15);border:2px solid var(--accent);display:flex;align-items:center;gap:12px;cursor:pointer">
          <span style="font-size:20px">🌌</span><span style="font-weight:600;font-size:14px">Mặc định · Tím huyền bí</span>
        </div>
        <div class="ob-theme-opt" onclick="pickObTheme(this,'ocean')" style="padding:12px 16px;border-radius:14px;background:rgba(255,255,255,.05);border:2px solid transparent;display:flex;align-items:center;gap:12px;cursor:pointer">
          <span style="font-size:20px">🌊</span><span style="font-weight:600;font-size:14px">Đại dương · Xanh biển</span>
        </div>
        <div class="ob-theme-opt" onclick="pickObTheme(this,'rose')" style="padding:12px 16px;border-radius:14px;background:rgba(255,255,255,.05);border:2px solid transparent;display:flex;align-items:center;gap:12px;cursor:pointer">
          <span style="font-size:20px">🌹</span><span style="font-weight:600;font-size:14px">Hồng · Lãng mạn</span>
        </div>
        <div class="ob-theme-opt" onclick="pickObTheme(this,'sunset')" style="padding:12px 16px;border-radius:14px;background:rgba(255,255,255,.05);border:2px solid transparent;display:flex;align-items:center;gap:12px;cursor:pointer">
          <span style="font-size:20px">🌅</span><span style="font-weight:600;font-size:14px">Hoàng hôn · Cam ấm</span>
        </div>
      </div>
      <button class="ob-btn" onclick="finishOnboarding()">Bắt đầu thôi! 🚀</button>
    </div>
  </div>

  <div class="ob-dots">
    <div class="ob-dot active" id="dot1"></div>
    <div class="ob-dot" id="dot2"></div>
    <div class="ob-dot" id="dot3"></div>
  </div>
</div>

<!-- ══════════ WELCOME ══════════ -->
<div id="welcomeScreen">
  <div class="welcome-emoji" id="welcomeEmoji">😎</div>
  <div class="welcome-text" id="welcomeText">Xin chào, Bums!</div>
  <div class="welcome-sub">BUMS Time đã sẵn sàng ✨</div>
  <div class="welcome-bar"><div class="welcome-bar-fill" id="welcomeBarFill"></div></div>
</div>

<!-- ══════════ MAIN APP ══════════ -->
<div id="app">

  <!-- PAGE: SCHEDULE -->
  <div class="page active" id="page-schedule">
    <div class="scroll-content">
      <div class="page-header">
        <div>
          <div class="page-title">Thời Gian Biểu</div>
          <div class="page-subtitle" id="scheduleSub">Hôm nay</div>
        </div>
        <div style="font-size:28px">📋</div>
      </div>

      <div id="scheduleNotif" class="notif-banner" onclick="openAddModal();dismissNotif('scheduleNotif')">
        <div class="nb-icon">💡</div>
        <div class="nb-text">
          <div class="nb-title">Bắt đầu lên kế hoạch nào!</div>
          <div class="nb-sub">Nhấn ＋ để thêm thời gian biểu đầu tiên</div>
        </div>
        <div class="nb-close" onclick="event.stopPropagation();dismissNotif('scheduleNotif')">✕</div>
      </div>

      <div class="section-label" id="scheduleSectionLabel" style="display:none">Danh sách</div>
      <div class="schedule-list" id="scheduleList"></div>

      <div class="empty-state" id="scheduleEmpty">
        <div class="empty-icon">🗒️</div>
        <div class="empty-title">Chưa có lịch nào</div>
        <div class="empty-sub">Thêm thời gian biểu đầu tiên của bạn<br>để bắt đầu quản lý ngày của mình!</div>
        <div class="empty-hint" onclick="openAddModal()">＋ Thêm thời gian biểu</div>
      </div>
    </div>
  </div>

  <!-- PAGE: CALENDAR -->
  <div class="page" id="page-calendar">
    <div class="scroll-content">
      <div class="page-header">
        <div>
          <div class="page-title">Lịch của bạn</div>
          <div class="page-subtitle">Quản lý lịch trình</div>
        </div>
        <div style="font-size:28px">📅</div>
      </div>

      <div id="calNotif" class="notif-banner" onclick="openAddModal();dismissNotif('calNotif')">
        <div class="nb-icon">📌</div>
        <div class="nb-text">
          <div class="nb-title">Lịch của bạn đang trống</div>
          <div class="nb-sub">Thêm sự kiện để không bỏ lỡ bất cứ điều gì!</div>
        </div>
        <div class="nb-close" onclick="event.stopPropagation();dismissNotif('calNotif')">✕</div>
      </div>

      <div class="cal-widget glass">
        <div class="cal-nav">
          <button class="cal-nav-btn" onclick="changeMonth(-1)">‹</button>
          <span class="cal-title" id="calTitle"></span>
          <button class="cal-nav-btn" onclick="changeMonth(1)">›</button>
        </div>
        <div class="cal-days-header">
          <div class="cal-day-name">CN</div><div class="cal-day-name">T2</div>
          <div class="cal-day-name">T3</div><div class="cal-day-name">T4</div>
          <div class="cal-day-name">T5</div><div class="cal-day-name">T6</div>
          <div class="cal-day-name">T7</div>
        </div>
        <div class="cal-grid" id="calGrid"></div>
      </div>

      <div class="section-label">Sự kiện — <span id="selectedDateLabel">hôm nay</span></div>
      <div class="event-timeline" id="eventTimeline">
        <div class="empty-state" style="padding:30px 20px">
          <div class="empty-icon" style="font-size:40px">📭</div>
          <div class="empty-sub">Chưa có sự kiện nào hôm nay</div>
          <div class="empty-hint" onclick="openAddModal()" style="margin-top:8px">＋ Thêm sự kiện</div>
        </div>
      </div>
    </div>
  </div>

  <!-- PAGE: CLOCK -->
  <div class="page" id="page-clock">
    <div class="scroll-content">
      <div class="page-header">
        <div>
          <div class="page-title">Đồng Hồ</div>
          <div class="page-subtitle">Thời gian & nhắc nhở</div>
        </div>
        <div style="font-size:28px">⏱️</div>
      </div>

      <div class="clock-tabs">
        <div class="clock-tab active" onclick="switchClockTab('analog',this)">Đồng hồ</div>
        <div class="clock-tab" onclick="switchClockTab('timer',this)">Hẹn giờ</div>
        <div class="clock-tab" onclick="switchClockTab('alarm',this)">Báo thức</div>
      </div>

      <div class="clock-panel active" id="panel-analog">
        <div class="analog-clock glass">
          <div class="clock-face">
            <div class="hand hand-hour" id="hourHand"></div>
            <div class="hand hand-min" id="minHand"></div>
            <div class="hand hand-sec" id="secHand"></div>
            <div class="clock-center"></div>
          </div>
        </div>
        <div class="digital-time" id="digitalTime">--:--:--</div>
        <div class="digital-date" id="digitalDate"></div>
      </div>

      <div class="clock-panel" id="panel-timer">
        <div class="timer-display" id="timerDisplay">00:00:00</div>
        <div class="timer-controls">
          <button class="timer-btn tbtn-reset" onclick="resetTimer()">↺</button>
          <button class="timer-btn tbtn-start" id="timerStartBtn" onclick="toggleTimer()">▶</button>
          <button class="timer-btn tbtn-stop" onclick="resetTimer()">⬛</button>
        </div>
        <div class="timer-presets">
          <div class="preset-chip" onclick="setTimer(60)">1 phút</div>
          <div class="preset-chip" onclick="setTimer(300)">5 phút</div>
          <div class="preset-chip" onclick="setTimer(600)">10 phút</div>
          <div class="preset-chip" onclick="setTimer(900)">15 phút</div>
          <div class="preset-chip" onclick="setTimer(1800)">30 phút</div>
          <div class="preset-chip" onclick="setTimer(3600)">1 giờ</div>
        </div>
      </div>

      <div class="clock-panel" id="panel-alarm">
        <div id="alarmNotif" class="notif-banner" style="width:100%;margin:0 0 14px" onclick="openAlarmModal()">
          <div class="nb-icon">⏰</div>
          <div class="nb-text">
            <div class="nb-title">Chưa có báo thức nào</div>
            <div class="nb-sub">Nhấn để thêm báo thức mới</div>
          </div>
          <div class="nb-close">＋</div>
        </div>
        <div class="alarm-list" id="alarmList"></div>
      </div>
    </div>
  </div>

  <!-- PAGE: WEATHER -->
  <div class="page" id="page-weather">
    <div class="scroll-content">
      <div class="page-header">
        <div>
          <div class="page-title">Thời Tiết</div>
          <div class="page-subtitle">Cập nhật hôm nay</div>
        </div>
        <div style="font-size:28px">🌤️</div>
      </div>

      <div class="weather-hero">
        <div class="weather-icon">⛅</div>
        <div class="weather-temp">28°C</div>
        <div class="weather-desc">Có mây nhẹ · Dễ chịu</div>
        <div class="weather-city">📍 Hà Nội, Việt Nam</div>
      </div>
      <div class="weather-stats">
        <div class="weather-stat glass"><div class="weather-stat-val">💧 72%</div><div class="weather-stat-label">Độ ẩm</div></div>
        <div class="weather-stat glass"><div class="weather-stat-val">🌬️ 12</div><div class="weather-stat-label">Gió km/h</div></div>
        <div class="weather-stat glass"><div class="weather-stat-val">☀️ UV6</div><div class="weather-stat-label">Chỉ số UV</div></div>
      </div>
      <div class="section-label">Dự báo 7 ngày</div>
      <div class="forecast-list" style="margin-bottom:20px">
        <div class="forecast-item glass"><span class="forecast-day">Hôm nay</span><span>⛅</span><span><span class="forecast-high">28°</span> <span class="forecast-low">/ 23°</span></span></div>
        <div class="forecast-item glass"><span class="forecast-day">Thứ 4</span><span>🌧️</span><span><span class="forecast-high">25°</span> <span class="forecast-low">/ 21°</span></span></div>
        <div class="forecast-item glass"><span class="forecast-day">Thứ 5</span><span>⛈️</span><span><span class="forecast-high">24°</span> <span class="forecast-low">/ 20°</span></span></div>
        <div class="forecast-item glass"><span class="forecast-day">Thứ 6</span><span>☀️</span><span><span class="forecast-high">31°</span> <span class="forecast-low">/ 24°</span></span></div>
        <div class="forecast-item glass"><span class="forecast-day">Thứ 7</span><span>🌤️</span><span><span class="forecast-high">30°</span> <span class="forecast-low">/ 23°</span></span></div>
        <div class="forecast-item glass"><span class="forecast-day">CN</span><span>☀️</span><span><span class="forecast-high">33°</span> <span class="forecast-low">/ 26°</span></span></div>
        <div class="forecast-item glass"><span class="forecast-day">Thứ 2</span><span>⛅</span><span><span class="forecast-high">29°</span> <span class="forecast-low">/ 22°</span></span></div>
      </div>
    </div>
  </div>

  <!-- PAGE: PROFILE -->
  <div class="page" id="page-profile">
    <div class="scroll-content">
      <div class="page-header">
        <div><div class="page-title">Tài Khoản</div><div class="page-subtitle">Cá nhân hoá trải nghiệm</div></div>
      </div>
      <div class="profile-hero glass">
        <div class="avatar-wrap">
          <div class="avatar" id="avatarEl" onclick="document.getElementById('avatarInput').click()">
            <img id="avatarImg" src="" alt="">
            <span id="avatarInitial">😎</span>
          </div>
          <div class="avatar-edit" onclick="document.getElementById('avatarInput').click()">✏️</div>
        </div>
        <input type="file" id="avatarInput" accept="image/*" onchange="handleAvatar(event)">
        <div class="profile-name" id="profileName">BUMS User</div>
        <div class="profile-email" id="profileEmail">bumstime@example.com</div>
        <div class="profile-stats">
          <div class="pstat"><div class="pstat-val" id="statTasks">0</div><div class="pstat-label">Nhiệm vụ</div></div>
          <div class="pstat"><div class="pstat-val" id="statDone">0</div><div class="pstat-label">Hoàn thành</div></div>
          <div class="pstat"><div class="pstat-val" id="statAlarms">0</div><div class="pstat-label">Báo thức</div></div>
        </div>
      </div>

      <div class="section-label">Giao diện</div>
      <div class="theme-grid">
        <div class="theme-chip glass active" onclick="applyTheme('default',this)"><span class="theme-icon">🌌</span>Mặc định</div>
        <div class="theme-chip glass" onclick="applyTheme('rose',this)"><span class="theme-icon">🌹</span>Hồng</div>
        <div class="theme-chip glass" onclick="applyTheme('ocean',this)"><span class="theme-icon">🌊</span>Biển</div>
        <div class="theme-chip glass" onclick="applyTheme('forest',this)"><span class="theme-icon">🌿</span>Rừng</div>
        <div class="theme-chip glass" onclick="applyTheme('sunset',this)"><span class="theme-icon">🌅</span>Hoàng hôn</div>
        <div class="theme-chip glass" onclick="applyTheme('midnight',this)"><span class="theme-icon">🌙</span>Đêm</div>
        <div class="theme-chip glass" onclick="applyTheme('candy',this)"><span class="theme-icon">🍬</span>Candy</div>
        <div class="theme-chip glass" onclick="applyTheme('gold',this)"><span class="theme-icon">⭐</span>Vàng</div>
      </div>

      <div class="section-label">Cài đặt</div>
      <div class="settings-list">
        <div class="settings-item glass" onclick="editProfile()">
          <div class="si-icon" style="background:rgba(108,99,255,.2)">👤</div>
          <div class="si-info"><div class="si-title">Chỉnh sửa hồ sơ</div><div class="si-sub">Tên, email, ảnh đại diện</div></div>
          <span class="si-arrow">›</span>
        </div>
        <div class="settings-item glass" onclick="showToast('🔔 Thông báo đang bật')">
          <div class="si-icon" style="background:rgba(255,159,10,.2)">🔔</div>
          <div class="si-info"><div class="si-title">Thông báo</div><div class="si-sub">Nhắc nhở, âm thanh</div></div>
          <span class="si-badge">Bật</span>
        </div>
        <div class="settings-item glass" onclick="showToast('🔒 Quyền riêng tư')">
          <div class="si-icon" style="background:rgba(48,209,88,.2)">🔒</div>
          <div class="si-info"><div class="si-title">Quyền riêng tư</div><div class="si-sub">Dữ liệu, bảo mật</div></div>
          <span class="si-arrow">›</span>
        </div>
        <div class="settings-item glass" onclick="showToast('☁️ Đang đồng bộ...')">
          <div class="si-icon" style="background:rgba(67,230,252,.2)">☁️</div>
          <div class="si-info"><div class="si-title">Đồng bộ đám mây</div><div class="si-sub">Lưu tất cả thiết bị</div></div>
          <span class="si-badge">✓</span>
        </div>
        <div class="settings-item glass" onclick="showToast('ℹ️ BUMS Time v2.0')">
          <div class="si-icon" style="background:rgba(255,255,255,.1)">ℹ️</div>
          <div class="si-info"><div class="si-title">Về ứng dụng</div><div class="si-sub">BUMS Time v2.0.0</div></div>
          <span class="si-arrow">›</span>
        </div>
      </div>
      <div style="height:20px"></div>
    </div>
  </div>

  <!-- BOTTOM NAV -->
  <nav class="bottom-nav">
    <div class="nav-item active" onclick="goTo('schedule',this)">
      <div class="nav-icon">📋</div>
      <span class="nav-label">Biểu</span>
    </div>
    <div class="nav-item" onclick="goTo('calendar',this)">
      <div class="nav-icon">📅</div>
      <span class="nav-label">Lịch</span>
    </div>
    <div class="nav-item" onclick="goTo('clock',this)">
      <div class="nav-icon">⏰</div>
      <span class="nav-label">Đồng hồ</span>
    </div>
    <div class="nav-item" onclick="goTo('weather',this)">
      <div class="nav-icon">🌤️</div>
      <span class="nav-label">Thời tiết</span>
    </div>
    <div class="nav-item" onclick="goTo('profile',this)">
      <div class="nav-icon" id="navAvatar">👤</div>
      <span class="nav-label">Tài khoản</span>
    </div>
  </nav>
</div>

<!-- FAB -->
<div class="fab" id="fab" onclick="openAddModal()">＋</div>

<!-- Modal: Add Schedule -->
<div class="modal-overlay" id="addModal" onclick="closeModalIfOutside(event)">
  <div class="modal">
    <div class="modal-pill"></div>
    <div class="modal-title">✨ Thêm thời gian biểu</div>
    <div class="form-group">
      <label class="form-label">Tiêu đề</label>
      <input class="form-input" id="inTitle" placeholder="Ví dụ: Học bài, Tập gym...">
    </div>
    <div class="form-group">
      <label class="form-label">Thời gian</label>
      <div style="display:flex;gap:10px">
        <input class="form-input" id="inStart" type="time" value="08:00" style="flex:1">
        <input class="form-input" id="inEnd" type="time" value="09:00" style="flex:1">
      </div>
    </div>
    <div class="form-group">
      <label class="form-label">Địa điểm</label>
      <input class="form-input" id="inPlace" placeholder="Phòng học, Online, Nhà...">
    </div>
    <div class="form-group">
      <label class="form-label">Màu sắc</label>
      <div class="color-picker-row">
        <div class="color-dot selected" style="background:#6C63FF" onclick="selectColor(this,'#6C63FF')"></div>
        <div class="color-dot" style="background:#FF6584" onclick="selectColor(this,'#FF6584')"></div>
        <div class="color-dot" style="background:#43E6FC" onclick="selectColor(this,'#43E6FC')"></div>
        <div class="color-dot" style="background:#FF9F0A" onclick="selectColor(this,'#FF9F0A')"></div>
        <div class="color-dot" style="background:#30D158" onclick="selectColor(this,'#30D158')"></div>
        <div class="color-dot" style="background:#FF453A" onclick="selectColor(this,'#FF453A')"></div>
      </div>
    </div>
    <div class="modal-actions">
      <button class="btn btn-secondary" onclick="closeModal('addModal')">Huỷ</button>
      <button class="btn btn-primary" onclick="addSchedule()">Thêm ✓</button>
    </div>
  </div>
</div>

<!-- Modal: Alarm -->
<div class="modal-overlay" id="alarmModal" onclick="closeModalIfOutside(event)">
  <div class="modal">
    <div class="modal-pill"></div>
    <div class="modal-title">⏰ Thêm báo thức</div>
    <div class="form-group">
      <label class="form-label">Giờ báo thức</label>
      <input class="form-input" id="inAlarmTime" type="time" value="07:00">
    </div>
    <div class="form-group">
      <label class="form-label">Nhãn</label>
      <input class="form-input" id="inAlarmLabel" placeholder="Tên báo thức...">
    </div>
    <div class="modal-actions">
      <button class="btn btn-secondary" onclick="closeModal('alarmModal')">Huỷ</button>
      <button class="btn btn-primary" onclick="addAlarm()">Thêm ✓</button>
    </div>
  </div>
</div>

<!-- Modal: Edit Profile -->
<div class="modal-overlay" id="profileModal" onclick="closeModalIfOutside(event)">
  <div class="modal">
    <div class="modal-pill"></div>
    <div class="modal-title">👤 Chỉnh sửa hồ sơ</div>
    <div class="form-group">
      <label class="form-label">Tên hiển thị</label>
      <input class="form-input" id="inName" placeholder="Tên của bạn">
    </div>
    <div class="form-group">
      <label class="form-label">Email</label>
      <input class="form-input" id="inEmail" placeholder="email@example.com" type="email">
    </div>
    <div class="modal-actions">
      <button class="btn btn-secondary" onclick="closeModal('profileModal')">Huỷ</button>
      <button class="btn btn-primary" onclick="saveProfile()">Lưu ✓</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ══ ONBOARDING STATE ══
let chosenAvatar = '😎';
let chosenTheme = 'default';
let userName = '';

function checkName() {
  const v = document.getElementById('obName').value.trim();
  const btn = document.getElementById('btnStep1');
  if (v.length > 0) { btn.style.opacity='1'; btn.style.pointerEvents='auto'; }
  else { btn.style.opacity='.5'; btn.style.pointerEvents='none'; }
}

function goStep(n) {
  if (n===1) { userName = ''; }
  if (n===2) {
    const v = document.getElementById('obName').value.trim();
    if (!v) return;
    userName = v;
  }
  document.querySelectorAll('.ob-step').forEach(s => s.classList.remove('active'));
  document.getElementById('ob-step-'+n).classList.add('active');
  document.querySelectorAll('.ob-dot').forEach((d,i) => {
    d.classList.toggle('active', i===n-1);
  });
}

function pickAv(el, emoji) {
  document.querySelectorAll('.av-opt').forEach(a => a.classList.remove('picked'));
  el.classList.add('picked');
  chosenAvatar = emoji;
}

function pickObTheme(el, theme) {
  document.querySelectorAll('.ob-theme-opt').forEach(o => {
    o.style.borderColor='transparent';
    o.style.background='rgba(255,255,255,.05)';
  });
  el.style.borderColor = 'var(--accent)';
  el.style.background = 'rgba(108,99,255,.15)';
  chosenTheme = theme;
  applyThemeByName(theme);
}

function finishOnboarding() {
  // apply theme & avatar
  applyThemeByName(chosenTheme);
  // show welcome screen
  document.getElementById('onboarding').style.display='none';
  const ws = document.getElementById('welcomeScreen');
  ws.style.display='flex';
  document.getElementById('welcomeEmoji').textContent = chosenAvatar;
  document.getElementById('welcomeText').textContent = `Xin chào, ${userName}! 🎉`;
  setTimeout(()=>{ document.getElementById('welcomeBarFill').style.width='100%'; },100);

  // set profile data
  document.getElementById('profileName').textContent = userName;
  document.getElementById('avatarInitial').textContent = chosenAvatar;
  document.getElementById('navAvatar').textContent = chosenAvatar;

  const now = new Date();
  const days=['Chủ Nhật','Thứ Hai','Thứ Ba','Thứ Tư','Thứ Năm','Thứ Sáu','Thứ Bảy'];
  document.getElementById('scheduleSub').textContent =
    `${days[now.getDay()]}, ${now.getDate()} tháng ${now.getMonth()+1}`;

  setTimeout(()=>{
    ws.style.display='none';
    document.getElementById('app').classList.add('visible');
    renderCalendar();
    updateClock();
  }, 2400);
}

// ══ NAV ══
function goTo(page, el) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-'+page).classList.add('active');
  el.classList.add('active');
  const fab = document.getElementById('fab');
  fab.style.display = (page==='schedule'||page==='calendar') ? 'flex' : 'none';
}

// ══ TOAST ══
let toastT;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  clearTimeout(toastT); toastT = setTimeout(()=>t.classList.remove('show'),2500);
}

// ══ MODAL ══
function openAddModal(){ document.getElementById('addModal').classList.add('open'); }
function openAlarmModal(){ document.getElementById('alarmModal').classList.add('open'); }
function editProfile(){
  document.getElementById('inName').value = document.getElementById('profileName').textContent;
  document.getElementById('inEmail').value = document.getElementById('profileEmail').textContent;
  document.getElementById('profileModal').classList.add('open');
}
function closeModal(id){ document.getElementById(id).classList.remove('open'); }
function closeModalIfOutside(e){ if(e.target===e.currentTarget) closeModal(e.currentTarget.id); }
function dismissNotif(id){
  const el=document.getElementById(id);
  if(el){ el.style.opacity='0'; el.style.transform='translateY(-10px)'; setTimeout(()=>el.remove(),300); }
}

// ══ COLOR ══
let selectedColor='#6C63FF';
function selectColor(el,c){
  document.querySelectorAll('.color-dot').forEach(d=>d.classList.remove('selected'));
  el.classList.add('selected'); selectedColor=c;
}

// ══ ADD SCHEDULE ══
const emojis=['📚','🏃','💻','🎨','🎵','🍳','📝','🏋️','🧘','🎮','📖','🎯','🌟','💼'];
let scheduleCount=0;
function addSchedule(){
  const title=document.getElementById('inTitle').value.trim();
  if(!title){ showToast('⚠️ Vui lòng nhập tiêu đề!'); return; }
  const start=document.getElementById('inStart').value;
  const end=document.getElementById('inEnd').value;
  const place=document.getElementById('inPlace').value;
  const emoji=emojis[scheduleCount%emojis.length];
  scheduleCount++;

  // hide empty state, show label
  document.getElementById('scheduleEmpty').style.display='none';
  document.getElementById('scheduleSectionLabel').style.display='block';

  const card=document.createElement('div');
  card.className='schedule-card glass';
  card.style.setProperty('--card-accent',selectedColor);
  card.innerHTML=`
    <div class="card-color" style="background:${selectedColor}22">${emoji}</div>
    <div class="card-info">
      <div class="card-title">${title}</div>
      <div class="card-time">⏰ ${start} – ${end}${place?' · '+place:''}</div>
    </div>
    <span class="card-badge" style="background:${selectedColor}22;color:${selectedColor}">Mới</span>
    <span class="card-del" onclick="deleteCard(this)">🗑️</span>
  `;
  document.getElementById('scheduleList').appendChild(card);
  closeModal('addModal');
  document.getElementById('inTitle').value='';
  document.getElementById('inPlace').value='';
  showToast('✅ Đã thêm thời gian biểu!');
  const n=parseInt(document.getElementById('statTasks').textContent)+1;
  document.getElementById('statTasks').textContent=n;
}

function deleteCard(el){
  const card=el.closest('.schedule-card');
  card.style.opacity='0'; card.style.transform='translateX(20px)'; card.style.transition='all .3s';
  setTimeout(()=>{
    card.remove();
    scheduleCount--;
    const n=Math.max(0,parseInt(document.getElementById('statTasks').textContent)-1);
    document.getElementById('statTasks').textContent=n;
    if(!document.getElementById('scheduleList').children.length){
      document.getElementById('scheduleEmpty').style.display='flex';
      document.getElementById('scheduleSectionLabel').style.display='none';
    }
  },300);
}

// ══ ALARM ══
let alarmCount=0;
function addAlarm(){
  const time=document.getElementById('inAlarmTime').value;
  const label=document.getElementById('inAlarmLabel').value||'Báo thức';
  alarmCount++;
  const item=document.createElement('div');
  item.className='alarm-item glass';
  item.innerHTML=`
    <div>
      <div class="alarm-time">${time}</div>
      <div class="alarm-label">${label}</div>
    </div>
    <div style="display:flex;gap:12px;align-items:center">
      <div class="toggle on" onclick="this.classList.toggle('on')"></div>
      <span style="font-size:18px;cursor:pointer;opacity:.6" onclick="this.closest('.alarm-item').remove();alarmCount--;document.getElementById('statAlarms').textContent=alarmCount;">🗑️</span>
    </div>
  `;
  // hide notif banner
  dismissNotif('alarmNotif');
  document.getElementById('alarmList').appendChild(item);
  closeModal('alarmModal');
  document.getElementById('inAlarmLabel').value='';
  showToast('⏰ Đã thêm báo thức!');
  document.getElementById('statAlarms').textContent=alarmCount;
}

// ══ SAVE PROFILE ══
function saveProfile(){
  const n=document.getElementById('inName').value.trim();
  const e=document.getElementById('inEmail').value.trim();
  if(n){ document.getElementById('profileName').textContent=n; }
  if(e){ document.getElementById('profileEmail').textContent=e; }
  closeModal('profileModal'); showToast('✅ Đã cập nhật hồ sơ!');
}

// ══ AVATAR ══
function handleAvatar(e){
  const file=e.target.files[0]; if(!file) return;
  const reader=new FileReader();
  reader.onload=ev=>{
    const img=document.getElementById('avatarImg');
    img.src=ev.target.result; img.style.display='block';
    document.getElementById('avatarInitial').style.display='none';
    document.getElementById('navAvatar').textContent='🖼️';
    showToast('✅ Đã cập nhật ảnh đại diện!');
  };
  reader.readAsDataURL(file);
}

// ══ CLOCK ══
function updateClock(){
  const now=new Date();
  const h=now.getHours(),m=now.getMinutes(),s=now.getSeconds();
  const hDeg=(h%12)*30+m*.5, mDeg=m*6+s*.1, sDeg=s*6;
  const hh=document.getElementById('hourHand');
  const mh=document.getElementById('minHand');
  const sh=document.getElementById('secHand');
  if(hh) hh.style.transform=`translateX(-50%) rotate(${hDeg}deg)`;
  if(mh) mh.style.transform=`translateX(-50%) rotate(${mDeg}deg)`;
  if(sh) sh.style.transform=`translateX(-50%) rotate(${sDeg}deg)`;
  const pad=n=>String(n).padStart(2,'0');
  const dt=document.getElementById('digitalTime');
  if(dt) dt.textContent=`${pad(h)}:${pad(m)}:${pad(s)}`;
  const days=['Chủ Nhật','Thứ Hai','Thứ Ba','Thứ Tư','Thứ Năm','Thứ Sáu','Thứ Bảy'];
  const dd=document.getElementById('digitalDate');
  if(dd) dd.textContent=`${days[now.getDay()]}, ${now.getDate()} tháng ${now.getMonth()+1} năm ${now.getFullYear()}`;
}
setInterval(updateClock,1000);

function switchClockTab(panel,el){
  document.querySelectorAll('.clock-tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.clock-panel').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('panel-'+panel).classList.add('active');
}

// ══ TIMER ══
let timerSec=0,timerRunning=false,timerInterval,timerSet=0;
function pad2(n){return String(Math.floor(n)).padStart(2,'0')}
function updateTimerDisplay(){
  const s=timerSet>0?Math.max(0,timerSet-timerSec):timerSec;
  document.getElementById('timerDisplay').textContent=`${pad2(s/3600)}:${pad2((s%3600)/60)}:${pad2(s%60)}`;
}
function toggleTimer(){
  if(timerRunning){clearInterval(timerInterval);timerRunning=false;document.getElementById('timerStartBtn').textContent='▶';}
  else{
    timerRunning=true;document.getElementById('timerStartBtn').textContent='⏸';
    timerInterval=setInterval(()=>{
      timerSec++;
      if(timerSet>0&&timerSec>=timerSet){clearInterval(timerInterval);timerRunning=false;document.getElementById('timerStartBtn').textContent='▶';showToast('⏰ Hẹn giờ xong!');}
      updateTimerDisplay();
    },1000);
  }
}
function resetTimer(){clearInterval(timerInterval);timerRunning=false;timerSec=0;timerSet=0;document.getElementById('timerStartBtn').textContent='▶';updateTimerDisplay();}
function setTimer(sec){resetTimer();timerSet=sec;timerSec=0;updateTimerDisplay();showToast(`⏱️ Đặt ${sec>=3600?sec/3600+' giờ':sec/60+' phút'}`);}

// ══ CALENDAR ══
let calDate=new Date();
function renderCalendar(){
  const y=calDate.getFullYear(),mo=calDate.getMonth();
  const months=['Tháng 1','Tháng 2','Tháng 3','Tháng 4','Tháng 5','Tháng 6','Tháng 7','Tháng 8','Tháng 9','Tháng 10','Tháng 11','Tháng 12'];
  document.getElementById('calTitle').textContent=`${months[mo]}, ${y}`;
  const firstDay=new Date(y,mo,1).getDay();
  const dim=new Date(y,mo+1,0).getDate();
  const prevDim=new Date(y,mo,0).getDate();
  const grid=document.getElementById('calGrid');
  grid.innerHTML='';
  const today=new Date();
  for(let i=firstDay-1;i>=0;i--){const c=document.createElement('div');c.className='cal-cell other-month';c.textContent=prevDim-i;grid.appendChild(c);}
  for(let d=1;d<=dim;d++){
    const c=document.createElement('div');c.className='cal-cell';c.textContent=d;
    if(d===today.getDate()&&mo===today.getMonth()&&y===today.getFullYear()) c.classList.add('today');
    c.onclick=()=>{
      document.querySelectorAll('.cal-cell').forEach(x=>x.classList.remove('selected'));
      c.classList.add('selected');
      document.getElementById('selectedDateLabel').textContent=`${d} tháng ${mo+1}`;
    };
    grid.appendChild(c);
  }
  const total=firstDay+dim;const rem=total%7===0?0:7-(total%7);
  for(let i=1;i<=rem;i++){const c=document.createElement('div');c.className='cal-cell other-month';c.textContent=i;grid.appendChild(c);}
}
function changeMonth(dir){calDate.setMonth(calDate.getMonth()+dir);renderCalendar();}

// ══ THEMES ══
const themes={
  default:{accent:'#6C63FF',accent2:'#FF6584',accent3:'#43E6FC',bg:'#0a0a1a',o1:'#6C63FF',o2:'#FF6584'},
  rose:{accent:'#FF2D55',accent2:'#FF6584',accent3:'#FF9F0A',bg:'#1a0a10',o1:'#FF2D55',o2:'#FF9F0A'},
  ocean:{accent:'#0A84FF',accent2:'#43E6FC',accent3:'#30D158',bg:'#020e1a',o1:'#0A84FF',o2:'#43E6FC'},
  forest:{accent:'#30D158',accent2:'#43E6FC',accent3:'#FF9F0A',bg:'#030e04',o1:'#30D158',o2:'#0A8F4C'},
  sunset:{accent:'#FF9F0A',accent2:'#FF453A',accent3:'#FF6584',bg:'#1a0a00',o1:'#FF9F0A',o2:'#FF453A'},
  midnight:{accent:'#5E5CE6',accent2:'#BF5AF2',accent3:'#64D2FF',bg:'#000010',o1:'#5E5CE6',o2:'#BF5AF2'},
  candy:{accent:'#FF6CAB',accent2:'#7AFDD6',accent3:'#FFE36E',bg:'#0d0010',o1:'#FF6CAB',o2:'#7AFDD6'},
  gold:{accent:'#FFD60A',accent2:'#FF9F0A',accent3:'#FFFACD',bg:'#0a0700',o1:'#FFD60A',o2:'#FF9F0A'},
};
function applyThemeByName(name){
  const t=themes[name];if(!t)return;
  const r=document.documentElement;
  r.style.setProperty('--accent',t.accent);r.style.setProperty('--accent2',t.accent2);
  r.style.setProperty('--accent3',t.accent3);r.style.setProperty('--bg-dark',t.bg);
  document.querySelector('.orb1').style.background=t.o1;
  document.querySelector('.orb2').style.background=t.o2;
}
function applyTheme(name,el){
  applyThemeByName(name);
  document.querySelectorAll('.theme-chip').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  showToast('🎨 Đã đổi giao diện!');
}

// ══ INIT ══
document.getElementById('fab').style.display='none';
// Enter on name input
document.getElementById('obName').addEventListener('keydown',e=>{if(e.key==='Enter')goStep(2);});
</script>
</body>
</html>
